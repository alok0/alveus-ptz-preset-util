{
  "name": "alveus-ptz-preset-util",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.17.1",
  "engines": {
    "node": "24.18.x"
  },
  "engineStrict": true,
  "scripts": {
