    "update-preset": "yarn node ./scripts/update-preset.mjs",
    "copy-screenshots": "yarn node --experimental-strip-types ./scripts/copy-screenshots.ts"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@fontsource-variable/jetbrains-mono": "5.3.0",
    "@mdi/js": "7.4.47",
    "@mui/icons-material": "9.2.0",
    "@mui/material": "9.2.0",
    "clsx": "2.1.1",
    "pannellum": "2.5.7",
    "preact": "10.29.7",
    "react": "19.2.7",
    "react-error-boundary": "6.1.2",
    "usehooks-ts": "3.1.1",
    "wouter": "3.10.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "5.17.3",
    "@eslint/js": "10.0.1",
    "@tsconfig/strictest": "2.0.8",
    "@tsconfig/vite-react": "8.1.1",
    "@types/eslint-plugin-jsx-a11y": "6.10.1",
    "@types/eslint-plugin-promise": "7.3.0",
    "@types/node": "24.13.3",
    "@types/pannellum": "2.5.1",
    "@types/react": "19.2.17",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-promise": "7.3.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "husky": "9.1.7",
    "lint-staged": "17.1.0",
    "prettier": "3.9.6",
    "sharp": "0.35.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.65.0",
    "vite": "8.1.5"
  }
